# ============================================================
# NEXUS BACKEND — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your credentials
# ============================================================

# ── DATABASE ─────────────────────────────────────────────────
# Option 1: Full connection string (recommended for cloud)
DATABASE_URL=postgresql://postgres:<your_password>@localhost:5432/nexus?sslmode=disable

# Option 2: Individual fields (used if DATABASE_URL is empty)
# DB_HOST=localhost
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=nexus
# DB_PORT=5432
# DB_SSLMODE=disable

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here

# --- RESEND (Email OTP) ---
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_API_KEY_HERE
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Nexus

# ── TWILIO (Phone OTP SMS) ────────────────────────────────────
# Get credentials at: https://console.twilio.com
TWILIO_ACCOUNT_SID=AC_YOUR_ACCOUNT_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_AUTH_TOKEN_HERE
TWILIO_PHONE_NUMBER=+1234567890

# ── SERVER ───────────────────────────────────────────────────
PORT=8080

# ── WEBAUTHN ─────────────────────────────────────────────────
WEBAUTHN_RPID=localhost
WEBAUTHN_RPORIGIN=http://localhost:8080
